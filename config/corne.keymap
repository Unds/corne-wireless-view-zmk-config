/*
 * Corne Keymap — Colemak-DH
 * Optimised for: general typing, email, spreadsheets, Python coding, CCH Axcess
 *
 * Layers:
 *   0 DEF  — Colemak-DH base, urob-style home row mods
 *   1 SYM  — Symbols & numbers
 *   2 NAV  — Navigation, clipboard, CCH Axcess
 *   3 FUN  — Function keys, Bluetooth, media
 *
 * Home row mods (left):  A=GUI  R=ALT  S=CTL  T=SFT
 * Home row mods (right): N=SFT  E=CTL  I=ALT  O=GUI
 */
#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>
/* ─── Layer aliases ───────────────────────────────────────── */
#define DEF 0
#define SYM 1
#define NAV 2
#define FUN 3
/ {
/* ─── Behaviours ──────────────────────────────────────────── */
behaviors {
    /*
     * hml — Home Row Mod Left
     * Only activates hold when the other key is on the RIGHT side.
     * This prevents accidental modifier triggers while typing normally.
     */
    hml: home_row_mod_left {
        compatible = "zmk,behavior-hold-tap";
        #binding-cells = <2>;
        flavor = "balanced";
        tapping-term-ms = <280>;
        quick-tap-ms = <175>;
        require-prior-idle-ms = <150>;
        bindings = <&kp>, <&kp>;
        hold-trigger-key-positions = <
            /* Right half — top row */    6  7  8  9  10 11
            /* Right half — home row */  18 19 20 21 22 23
            /* Right half — bot row */   30 31 32 33 34 35
            /* Thumb keys */             36 37 38 39 40 41
        >;
        hold-trigger-on-release;
    };
    /*
     * hmr — Home Row Mod Right
     * Only activates hold when the other key is on the LEFT side.
     */
    hmr: home_row_mod_right {
        compatible = "zmk,behavior-hold-tap";
        #binding-cells = <2>;
        flavor = "balanced";
        tapping-term-ms = <280>;
        quick-tap-ms = <175>;
        require-prior-idle-ms = <150>;
        bindings = <&kp>, <&kp>;
        hold-trigger-key-positions = <
            /* Left half — top row */     0  1  2  3  4  5
            /* Left half — home row */   12 13 14 15 16 17
            /* Left half — bot row */    24 25 26 27 28 29
            /* Thumb keys */             36 37 38 39 40 41
        >;
        hold-trigger-on-release;
    };
    /*
     * lt_bspc — Layer-tap with Backspace
     * Tap = Backspace, Hold = NAV layer
     */
    lt_bspc: layer_tap_backspace {
        compatible = "zmk,behavior-hold-tap";
        #binding-cells = <2>;
        flavor = "balanced";
        tapping-term-ms = <200>;
        quick-tap-ms = <175>;
        bindings = <&mo>, <&kp>;
    };
};
/* ─── Combos ──────────────────────────────────────────────── */
combos {
    compatible = "zmk,combos";
    /* N + E (right hand index fingers) = Escape */
    combo_esc {
        timeout-ms = <50>;
        key-positions = <19 20>;
        bindings = <&kp ESC>;
    };
    /* LSFT + RSFT = Caps Word (type ONE_WORD in caps then auto-off) */
    combo_caps_word {
        timeout-ms = <50>;
        key-positions = <24 35>;
        bindings = <&caps_word>;
    };
    /* S + T (left hand) = Tab  — useful in CCH Axcess */
    combo_tab {
        timeout-ms = <40>;
        key-positions = <15 16>;
        bindings = <&kp TAB>;
    };
};
/* ─── Keymap ──────────────────────────────────────────────── */
keymap {
    compatible = "zmk,keymap";
    /* ══════════════════════════════════════════════════════════
     * LAYER 0 — DEF (Colemak-DH)
     *
     * ┌──────┬─────┬─────┬─────┬─────┬─────┐   ┌─────┬─────┬─────┬─────┬─────┬──────┐
     * │ TAB  │  Q  │  W  │  F  │  P  │  B  │   │  J  │  L  │  U  │  Y  │  '  │ BSPC │
     * ├──────┼─────┼─────┼─────┼─────┼─────┤   ├─────┼─────┼─────┼─────┼─────┼──────┤
     * │ESC/FN│A/GUI│R/ALT│S/CTL│T/SFT│  G  │   │  M  │N/SFT│E/CTL│I/ALT│O/GUI│ ;/FN │
     * ├──────┼─────┼─────┼─────┼─────┼─────┤   ├─────┼─────┼─────┼─────┼─────┼──────┤
     * │ LSFT │  Z  │  X  │  C  │  D  │  V  │   │  K  │  H  │  ,  │  .  │  /  │ RSFT │
     * └──────┴─────┴─────┼─────┼─────┼─────┤   ├─────┼─────┼─────┼─────┴─────┴──────┘
     *                    │ NAV │ SPC │ SYM │   │ DEL │BSPC │ ENT │
     *                    └─────┴─────┴─────┘   └─────┴─────┴─────┘
     * ══════════════════════════════════════════════════════════ */
    default_layer {
        bindings = <
            &kp TAB          &kp Q            &kp W            &kp F             &kp P             &kp B
            &lt FUN ESC      &hml LGUI A      &hml LALT R      &hml LCTRL S      &hml LSHFT T      &kp G
            &kp LSHFT        &kp Z            &kp X            &kp C             &kp D             &kp V
                                              &mo NAV          &kp SPACE         &mo SYM
                             &kp J            &kp L            &kp U             &kp Y             &kp SQT          &kp BSPC
                             &kp M            &hmr RSHFT N     &hmr RCTRL E      &hmr RALT I       &hmr RGUI O      &lt FUN SEMI
                             &kp K            &kp H            &kp COMMA         &kp DOT           &kp FSLH         &kp RSHFT
                             &kp DEL          &kp BSPC         &kp RET
        >;
    };
    /* ══════════════════════════════════════════════════════════
     * LAYER 1 — SYM (Symbols & Numbers)
     *
     * ┌─────┬─────┬─────┬─────┬─────┬─────┐   ┌─────┬─────┬─────┬─────┬─────┬─────┐
     * │  ^  │  1  │  2  │  3  │  4  │  5  │   │  6  │  7  │  8  │  9  │  0  │  ?  │
     * ├─────┼─────┼─────┼─────┼─────┼─────┤   ├─────┼─────┼─────┼─────┼─────┼─────┤
     * │  &  │  !  │  @  │  #  │  $  │  %  │   │  =  │  (  │  )  │  [  │  ]  │  :  │
     * ├─────┼─────┼─────┼─────┼─────┼─────┤   ├─────┼─────┼─────┼─────┼─────┼─────┤
     * │  *  │  \  │  |  │  `  │  ~  │  "  │   │  -  │  +  │  {  │  }  │  _  │  <> │
     * └─────┴─────┴─────┼─────┼─────┼─────┤   ├─────┼─────┼─────┼─────┴─────┴─────┘
     *                   │ ▼   │ SPC │ ▼   │   │ DEL │BSPC │ ENT │
     *                   └─────┴─────┴─────┘   └─────┴─────┴─────┘
     * ══════════════════════════════════════════════════════════ */
    sym_layer {
        bindings = <
            &kp CARET        &kp N1           &kp N2           &kp N3            &kp N4            &kp N5
            &kp AMPS         &kp EXCL         &kp AT           &kp HASH          &kp DLLR          &kp PRCNT
            &kp ASTRK        &kp BSLH         &kp PIPE         &kp GRAVE         &kp TILDE         &kp DQT
                                              &trans           &kp SPACE         &trans
                             &kp N6           &kp N7           &kp N8            &kp N9            &kp N0           &kp QMARK
                             &kp EQUAL        &kp LPAR         &kp RPAR          &kp LBKT          &kp RBKT         &kp COLON
                             &kp MINUS        &kp PLUS         &kp LBRC          &kp RBRC          &kp UNDER        &kp LT
                             &kp DEL          &kp BSPC         &kp RET
        >;
    };
    /* ══════════════════════════════════════════════════════════
     * LAYER 2 — NAV (Navigation)
     *
     * ┌──────┬──────┬──────┬──────┬──────┬──────┐   ┌──────┬──────┬──────┬──────┬──────┬──────┐
     * │ C+Z  │ C+Z  │ C+X  │ C+C  │ C+V  │ C+Y  │   │S+HOM │ HOME │  ↑   │ END  │ S+END│ INS  │
     * ├──────┼──────┼──────┼──────┼──────┼──────┤   ├──────┼──────┼──────┼──────┼──────┼──────┤
     * │ C+A  │ C+A  │ C+S  │ C+F  │ C+W  │ C+T  │   │ C+←  │  ←   │  ↓   │  →   │ C+→  │C+HOM │
     * ├──────┼──────┼──────┼──────┼──────┼──────┤   ├──────┼──────┼──────┼──────┼──────┼──────┤
     * │ PGUP │ PGUP │ PGDN │      │      │      │   │S+TAB │ TAB  │ C+↓  │ C+↑  │C+END │ APP  │
     * └──────┴──────┴──────┼──────┼──────┼──────┤   ├──────┼──────┼──────┼──────┴──────┴──────┘
     *                      │  ▼   │ SPC  │      │   │ DEL  │ BSPC │ ENT  │
     *                      └──────┴──────┴──────┘   └──────┴──────┴──────┘
     * ══════════════════════════════════════════════════════════ */
    nav_layer {
        bindings = <
            &kp LC(Z)        &kp LC(Z)        &kp LC(X)        &kp LC(C)         &kp LC(V)         &kp LC(Y)
            &kp LC(A)        &kp LC(A)        &kp LC(S)        &kp LC(F)         &kp LC(W)         &kp LC(T)
            &kp PG_UP        &kp PG_UP        &kp PG_DN        &trans            &trans            &trans
                                              &trans           &kp SPACE         &trans
                             &kp LS(HOME)     &kp HOME         &kp UP            &kp END           &kp LS(END)      &kp INS
                             &kp LC(LEFT)     &kp LEFT         &kp DOWN          &kp RIGHT         &kp LC(RIGHT)    &kp LC(HOME)
                             &kp LS(TAB)      &kp TAB          &kp LC(DOWN)      &kp LC(UP)        &kp LC(END)      &kp K_APP
                             &kp DEL          &kp BSPC         &kp RET
        >;
    };
    /* ══════════════════════════════════════════════════════════
     * LAYER 3 — FUN (Function / Bluetooth / Media)
     *
     * ┌─────┬─────┬─────┬─────┬─────┬─────┐   ┌─────┬─────┬─────┬─────┬──────┬─────┐
     * │     │ F1  │ F2  │ F3  │ F4  │ F5  │   │ BT0 │ BT1 │ BT2 │ BT3 │BTCLR │     │
     * ├─────┼─────┼─────┼─────┼─────┼─────┤   ├─────┼─────┼─────┼─────┼──────┼─────┤
     * │ ▼   │ F6  │ F7  │ F8  │ F9  │ F10 │   │ ◀◀  │ ▶⏸  │ ▶▶  │MUTE │ VOL- │VOL+ │
     * ├─────┼─────┼─────┼─────┼─────┼─────┤   ├─────┼─────┼─────┼─────┼──────┼─────┤
     * │     │ F11 │ F12 │PSCR │SLCK │PAUS │   │     │BRI- │BRI+ │     │      │ ▼   │
     * └─────┴─────┴─────┼─────┼─────┼─────┤   ├─────┼─────┼─────┼─────┴──────┴─────┘
     *                   │     │     │ ▼   │   │ DEL │BSPC │ ENT │
     *                   └─────┴─────┴─────┘   └─────┴─────┴─────┘
     * ══════════════════════════════════════════════════════════ */
    fun_layer {
        bindings = <
            &trans           &kp F1           &kp F2           &kp F3            &kp F4            &kp F5
            &trans           &kp F6           &kp F7           &kp F8            &kp F9            &kp F10
            &trans           &kp F11          &kp F12          &kp PSCRN         &kp SLCK          &kp PAUSE_BREAK
                                              &trans           &trans            &trans
                             &bt BT_SEL 0     &bt BT_SEL 1     &bt BT_SEL 2      &bt BT_SEL 3      &bt BT_CLR       &trans
                             &kp C_PREV       &kp C_PP         &kp C_NEXT        &kp C_MUTE        &kp C_VOL_DN     &kp C_VOL_UP
                             &trans           &kp C_BRI_DN     &kp C_BRI_UP      &trans            &trans           &trans
                             &kp DEL          &kp BSPC         &kp RET
        >;
    };
}; /* keymap */
}; /* / */
