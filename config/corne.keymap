/*
 * ============================================================
 * Corne (CRKBD) Keymap - Productivity & Development Optimized
 * ============================================================
 * Hardware: nice!nano v2 + nice!view
 * OS: Windows
 * Use Cases: Gmail (shortcuts mode), Google Sheets, Adobe Acrobat, VS Code (Python/C++)
 * Features: Home Row Mods, One-handed navigation, App-specific shortcuts
 * 
 * Author Notes:
 * - Space on LEFT thumb for comfort
 * - Home row mods: GUI/Alt/Ctrl/Shift (GACS order)
 * - Beginner-friendly timing for smooth learning curve
 * - Numbers/symbols optimized for data entry and coding
 */

#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>

/ {
    behaviors {
        /*
         * Home Row Mods - Optimized for beginners
         * - 200ms hold time: comfortable for learning
         * - require-prior-idle-ms: prevents accidental activation while fast typing
         * - balanced flavor: best for mixed typing and shortcuts
         */

        hm: homerow_mods {
            compatible = "zmk,behavior-hold-tap";
            label = "HOMEROW_MODS";
            #binding-cells = <2>;
            tapping-term-ms = <200>;
            quick-tap-ms = <175>;
            require-prior-idle-ms = <150>;
            flavor = "balanced";
            bindings = <&kp>, <&kp>;
        };

        /*
         * Shift on Caps Word - Sticky shift for typing CONSTANTS or SQL
         */

        skq: sticky_key_quick_release {
            compatible = "zmk,behavior-sticky-key";
            label = "STICKY_KEY_QUICK_RELEASE";
            #binding-cells = <1>;
            bindings = <&kp>;
            release-after-ms = <1000>;
            quick-release;
        };
    };

    /*
     * Combo Keys - Quick access without layer switching
     * Useful for common shortcuts while keeping hands on home row
     */

    combos {
        compatible = "zmk,combos";

        // ESC: Q + W (top left corner for quick escape)

        combo_esc {
            timeout-ms = <50>;
            key-positions = <1 2>;
            bindings = <&kp ESC>;
        };

        // Tab: W + E (useful for Gmail 'g then i' workflow)

        combo_tab {
            timeout-ms = <50>;
            key-positions = <2 3>;
            bindings = <&kp TAB>;
        };

        // Caps Word: Both Shifts (F + J) - For typing SQL, CONSTANTS

        combo_caps_word {
            timeout-ms = <50>;
            key-positions = <16 19>;
            bindings = <&caps_word>;
        };

        // Delete: Backspace combo (O + P)

        combo_del {
            timeout-ms = <50>;
            key-positions = <8 9>;
            bindings = <&kp DEL>;
        };

        // Screenshot: Win + Shift + S (common on Windows)

        combo_screenshot {
            timeout-ms = <50>;
            key-positions = <25 26>;
            bindings = <&kp LG(LS(S))>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        /*
         * ================================================================
         * LAYER 0: BASE (QWERTY with Home Row Mods)
         * ================================================================
         * Primary layer for typing and Gmail shortcuts
         * Home row mods: GUI(Win) / Alt / Ctrl / Shift on ASDF & JKL;
         * Space on LEFT thumb for natural reach
         */

        base_layer {
            label = "BASE";
            bindings = <
&kp TAB    &kp Q  &kp W  &kp F         &kp P  &kp B        &kp J    &kp L  &kp U      &kp Y    &kp SEMI  &kp BSPC
&kp ESC    &kp A  &kp R  &kp S         &kp T  &kp G        &kp M    &kp N  &kp E      &kp I    &kp O     &kp SQT
&kp LSHFT  &kp Z  &kp X  &kp C         &kp D  &kp V        &kp K    &kp H  &kp COMMA  &kp DOT  &kp FSLH  &kp RSHFT
                         &kp LEFT_GUI  &mo 1  &kp SPACE    &kp RET  &mo 2  &kp RALT
            >;
        };

        /*
         * ================================================================
         * LAYER 1: LOWER (Numbers, Symbols, Navigation)
         * ================================================================
         * Accessed by holding LEFT thumb key (second position)
         * Optimized for:
         * - Number entry (Google Sheets data entry)
         * - Common symbols and punctuation
         * - One-handed arrow navigation on right side
         */

        NUM_SYMB {
            label = "NUM&SYM";
            bindings = <
&kp GRAVE     &kp N1        &kp N2        &kp N3    &kp N4         &kp N5         &kp N6     &kp N7        &kp N8        &kp N9        &kp N0     &kp LS(QMARK)
&kp LS(DLLR)  &kp LS(EXCL)  &kp AT        &kp HASH  &kp DLLR       &kp PRCNT      &kp EQUAL  &kp LS(LPAR)  &kp LS(RPAR)  &kp LBKT      &kp RBKT   &kp LS(COLON)
&kp LS(STAR)  &kp BSLH      &kp LS(PIPE)  &kp SQT   &kp LS(TILDE)  &kp LS(DQT)    &kp MINUS  &kp PLUS      &kp LS(LBRC)  &kp LS(RBRC)  &kp MINUS  &kp N0
                                          &trans    &trans         &trans         &trans     &mo 3         &trans
            >;
        };

        /*
         * ================================================================
         * LAYER 2: RAISE (Coding Symbols, Functions, Brackets)
         * ================================================================
         * Accessed by holding RIGHT thumb key (second position)
         * Optimized for:
         * - Python/C++ coding (brackets, operators, underscores)
         * - Function keys (F1-F12)
         * - Media controls
         */

        NAV {
            label = "NAV";
            bindings = <
&kp PAGE_UP  &kp PAGE_DOWN  &kp LC(W)  &trans     &kp LC(T)  &kp LC(Y)    &kp LS(HOME)  &kp HOME       &kp UP_ARROW  &kp END       &kp LS(END)    &kp INS
&kp LC(A)    &kp LC(S)      &trans     &kp LC(F)  &kp LBKT   &kp RBKT     &kp LC(LEFT)  &kp LEFT       &kp DOWN      &kp RIGHT     &kp LC(RIGHT)  &kp LS(UP_ARROW)
&kp LC(Z)    &kp LC(X)      &kp LC(C)  &kp LC(V)  &kp LT     &kp GT       &kp LS(TAB)   &kp TAB        &kp LS(LEFT)  &kp LS(DOWN)  &kp LS(RIGHT)  &kp K_APP
                                       &trans     &mo 3      &trans       &kp DEL       &kp BACKSPACE  &kp ENTER
            >;
        };

        /*
         * ================================================================
         * LAYER 3: ADJUST (System, Shortcuts, Bluetooth)
         * ================================================================
         * Accessed by holding BOTH thumb layer keys (Layer 1 + 2)
         * Contains:
         * - Gmail shortcuts (left side)
         * - VS Code shortcuts (right side)
         * - Bluetooth controls (top left)
         * - System controls
         */

        FN_BT {
            label = "FUNC & BT";
            bindings = <
&trans  &kp F1   &kp F2   &kp F3           &kp F4          &kp F5             &bt BT_SEL 0  &bt BT_SEL 1      &bt BT_SEL 2  &bt BT_SEL 3  &bt BT_CLR    &kp C_VOLUME_UP
&trans  &kp F6   &kp F7   &kp F8           &kp F9          &kp F10            &kp C_PREV    &kp C_PLAY_PAUSE  &kp C_NEXT    &kp C_MUTE    &kp C_VOL_DN  &trans
&trans  &kp F11  &kp F12  &kp PRINTSCREEN  &kp SCROLLLOCK  &kp PAUSE_BREAK    &trans        &none             &none         &none         &none         &trans
                          &trans           &trans          &trans             &trans        &trans            &trans
            >;
        };
    };
};
